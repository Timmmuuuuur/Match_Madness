    {
      "id": "questions",
      "number": 3,
      "title": "Questions & negation",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Questions use question words (<em>кто, что, где, когда, почему, как</em>) or intonation. Negation uses <code>не</code> or <code>ни</code> depending on context."
        },
        {
          "type": "example",
          "fr": "Вы говорите по-русски?",
          "en": "Do you speak Russian?"
        }
      ]
