          "exampleEn": "He has an open mind."
        },
        {
          "meaning": "spirit, ghost",
          "connotation": "Esprit de Noël = Christmas spirit.",
          "exampleFr": "L'esprit de l'équipe.",
          "exampleEn": "Team spirit."
        }
