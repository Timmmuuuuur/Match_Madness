        {
          "meaning": "tower",
          "connotation": "La tour Eiffel.",
          "exampleFr": "Une haute tour.",
          "exampleEn": "A tall tower."
        },
        {
          "meaning": "turn, round (it's your turn)",
          "connotation": "À ton tour = your turn.",
          "exampleFr": "C'est ton tour.",
          "exampleEn": "It's your turn."
        },
        {
          "meaning": "tour, trip",
          "connotation": "Un tour du monde.",
          "exampleFr": "Un tour de France.",
          "exampleEn": "A tour of France."
        }
      ]
    },
    "air": {
      "pos": "noun (m.)",
      "register": "neutral",
      "primary": "air",
      "senses": [
        {
          "meaning": "air (atmosphere)",
          "connotation": "L'air pur = fresh air.",
          "exampleFr": "Prends l'air.",
          "exampleEn": "Get some fresh air."
        },
        {
          "meaning": "look, appearance (avoir l'air)",
          "connotation": "Avoir l'air de = to look like, seem.",
          "exampleFr": "Tu as l'air fatigué.",
          "exampleEn": "You look tired."
        },
        {
          "meaning": "tune, melody (musical air)",
          "connotation": "Less common; literary.",
          "exampleFr": "Un air connu.",
          "exampleEn": "A well-known tune."
        }
      ]
    },
    "voix": {
      "pos": "noun (f.)",
      "register": "neutral",
      "primary": "voice",
      "senses": [
        {
          "meaning": "voice",
          "connotation": "Physical or singing voice.",
          "exampleFr": "Elle a une belle voix.",
          "exampleEn": "She has a beautiful voice."
        },
        {
          "meaning": "vote",
          "connotation": "Donner sa voix = to cast one's vote.",
          "exampleFr": "À voix haute.",
          "exampleEn": "Aloud (lit. in loud voice)."
        }
      ]
    },
    "place": {
      "pos": "noun (f.)",
      "register": "neutral",
      "primary": "place / square / seat",
      "senses": [
        {
          "meaning": "place, spot, room",
          "connotation": "Avoir de la place = have room.",
          "exampleFr": "Il n'y a plus de place.",
          "exampleEn": "There is no more room."
        },
        {
          "meaning": "town square",
          "connotation": "La place de la République.",
          "exampleFr": "On se retrouve sur la place.",
          "exampleEn": "Let's meet in the square."
        },
        {
          "meaning": "seat (reserved place)",
          "connotation": "Prendre place = take a seat.",
          "exampleFr": "Gardez votre place.",
          "exampleEn": "Keep your seat."
        }
      ]
