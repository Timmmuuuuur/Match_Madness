      "senses": [
        {
          "meaning": "language",
          "connotation": "La langue française.",
          "exampleFr": "Quelle langue parles-tu ?",
          "exampleEn": "What language do you speak?"
        },
        {
          "meaning": "tongue (body part)",
          "connotation": "Physical organ; se mordre la langue.",
          "exampleFr": "Se mordre la langue.",
          "exampleEn": "To bite one's tongue."
        }
      ]
    },
    "esprit": {
