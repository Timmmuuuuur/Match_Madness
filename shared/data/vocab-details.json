{
  "entries": {
    "temps": {
      "pos": "noun (m.)",
      "register": "neutral — among the most frequent French nouns",
      "primary": "time",
      "note": "Two core meanings; context usually disambiguates.",
      "senses": [
        {
          "meaning": "time (duration, moment, availability)",
          "connotation": "Abstract; omnipresent in daily speech.",
          "exampleFr": "Je n'ai pas le temps.",
          "exampleEn": "I don't have time."
        },
        {
          "meaning": "weather",
          "connotation": "Almost always in « il fait … temps » constructions.",
          "exampleFr": "Il fait mauvais temps.",
          "exampleEn": "The weather is bad."
        }
      ]
    },
    "est": {
      "pos": "verb / noun / adjective",
      "register": "neutral",
      "primary": "is (from être)",
      "note": "Homograph with geographic « east » and proper noun Mars.",
      "senses": [
        {
          "meaning": "is (3rd person singular of être)",
          "connotation": "Copula; links subject to description.",
          "exampleFr": "Il est médecin.",
          "exampleEn": "He is a doctor."
        },
        {
          "meaning": "east (noun/adj.)",
          "connotation": "Direction; often capitalized as l'Est.",
          "exampleFr": "Le vent vient de l'est.",
          "exampleEn": "The wind comes from the east."
        }
      ]
    },
    "son": {
      "pos": "determiner / noun (m.)",
      "register": "neutral",
      "primary": "his / its / her",
      "note": "Possessive before masculine nouns; homograph with « sound ».",
      "senses": [
        {
          "meaning": "his, her, its (possessive)",
          "connotation": "Agrees with the noun that follows, not the owner.",
          "exampleFr": "Il a perdu son téléphone.",
          "exampleEn": "He lost his phone."
        },
        {
          "meaning": "sound",
          "connotation": "Auditory; le son = the sound.",
          "exampleFr": "Le son est trop fort.",
          "exampleEn": "The sound is too loud."
        }
      ]
    },
    "fait": {
      "pos": "noun (m.) / past participle",
      "register": "neutral",
      "primary": "fact / made",
      "note": "Past participle of faire; also a standalone noun.",
      "senses": [
        {
          "meaning": "fact, deed",
          "connotation": "En fait = actually / in fact.",
          "exampleFr": "C'est un fait connu.",
          "exampleEn": "It is a known fact."
        },
        {
          "meaning": "made, done (participle)",
          "connotation": "Used in compound tenses with avoir.",
          "exampleFr": "Il a fait ses devoirs.",
          "exampleEn": "He did his homework."
        }
      ]
    },
    "même": {
      "pos": "adjective / adverb",
      "register": "neutral",
      "primary": "same",
      "note": "Also means « even » when placed before a noun or verb.",
      "senses": [
        {
          "meaning": "same, identical",
          "connotation": "Emphasizes sameness; often with definite article.",
          "exampleFr": "Nous avons la même idée.",
          "exampleEn": "We have the same idea."
        },
        {
          "meaning": "even (emphasis)",
          "connotation": "Intensifier; can surprise the listener.",
          "exampleFr": "Même lui ne le savait pas.",
          "exampleEn": "Even he didn't know."
        }
      ]
    },
    "histoire": {
      "pos": "noun (f.)",
      "register": "neutral",
      "primary": "history / story",
      "note": "Same word for academic history and narrative fiction.",
      "senses": [
        {
          "meaning": "history (events of the past)",
          "connotation": "Academic or collective past.",
          "exampleFr": "L'histoire de France est longue.",
          "exampleEn": "The history of France is long."
        },
        {
          "meaning": "story, tale",
          "connotation": "Narrative; often for children or anecdotes.",
          "exampleFr": "Raconte-moi une histoire.",
          "exampleEn": "Tell me a story."
        }
      ]
    },
    "droit": {
      "pos": "noun (m.) / adjective",
      "register": "formal to neutral",
      "primary": "right / law / straight",
      "note": "Legal, directional, and moral senses overlap in fixed phrases.",
      "senses": [
        {
          "meaning": "right (legal or moral entitlement)",
          "connotation": "Avoir le droit de = to have the right to.",
          "exampleFr": "C'est mon droit.",
          "exampleEn": "It is my right."
        },
        {
          "meaning": "law (field or body of rules)",
          "connotation": "Étudier le droit = study law.",
          "exampleFr": "Elle étudie le droit.",
          "exampleEn": "She studies law."
        },
        {
          "meaning": "straight (direction)",
          "connotation": "Tout droit = straight ahead.",
          "exampleFr": "Allez tout droit.",
          "exampleEn": "Go straight ahead."
        }
      ]
    },
    "sens": {
      "pos": "noun (m.)",
      "register": "neutral",
      "primary": "meaning / direction / sense",
      "senses": [
        {
          "meaning": "meaning (of a word or phrase)",
          "connotation": "Quel est le sens de…? = What does … mean?",
          "exampleFr": "Quel est le sens de ce mot ?",
          "exampleEn": "What is the meaning of this word?"
        },
        {
          "meaning": "direction",
          "connotation": "Dans quel sens ? = Which way?",
          "exampleFr": "Dans le sens inverse.",
          "exampleEn": "In the opposite direction."
        },
        {
          "meaning": "sense (one of five senses)",
          "connotation": "Le sens de l'odorat = sense of smell.",
          "exampleFr": "Le sens du toucher.",
          "exampleEn": "The sense of touch."
        }
      ]
    },
    "livre": {
      "pos": "noun (m.)",
      "register": "neutral",
      "primary": "book",
      "note": "Also the old currency unit « pound » in historical contexts.",
      "senses": [
        {
          "meaning": "book",
          "connotation": "Most common sense today.",
          "exampleFr": "J'ai acheté un livre.",
          "exampleEn": "I bought a book."
        },
        {
          "meaning": "pound (currency, historical)",
          "connotation": "Livre sterling = pound sterling.",
          "exampleFr": "Cinq livres sterling.",
          "exampleEn": "Five pounds sterling."
        }
      ]
    },
    "fils": {
      "pos": "noun (m.)",
      "register": "neutral",
      "primary": "son",
      "senses": [
        {
          "meaning": "son",
          "connotation": "Family relationship; plural irregular: des fils.",
          "exampleFr": "Son fils a dix ans.",
          "exampleEn": "His son is ten years old."
        },
        {
          "meaning": "wire, thread",
          "connotation": "Technical; fil de fer = iron wire.",
          "exampleFr": "Un fil de cuivre.",
          "exampleEn": "A copper wire."
        }
      ]
    },
    "parti": {
      "pos": "noun (m.)",
      "register": "neutral to political",
      "primary": "party (political)",
      "senses": [
        {
          "meaning": "political party",
          "connotation": "Le Parti socialiste, etc.",
          "exampleFr": "Il est membre d'un parti.",
          "exampleEn": "He is a member of a party."
        },
        {
          "meaning": "departure; decision (avoir pris son parti)",
          "connotation": "Idiomatic: s'en prendre à = to blame.",
          "exampleFr": "J'ai pris mon parti.",
          "exampleEn": "I've made up my mind."
        }
      ]
    },
    "femme": {
      "pos": "noun (f.)",
      "register": "neutral",
      "primary": "woman",
      "senses": [
        {
          "meaning": "woman",
          "connotation": "General; une femme = a woman.",
          "exampleFr": "C'est une femme intelligente.",
          "exampleEn": "She is an intelligent woman."
        },
        {
          "meaning": "wife",
          "connotation": "Often with possessive: ma femme.",
          "exampleFr": "Ma femme travaille à Paris.",
          "exampleEn": "My wife works in Paris."
        }
      ]
    },
    "argent": {
      "pos": "noun (m.)",
      "register": "neutral",
      "primary": "money",
      "senses": [
        {
          "meaning": "money",
          "connotation": "Most frequent sense; l'argent = money in general.",
          "exampleFr": "Je n'ai pas d'argent.",
          "exampleEn": "I don't have money."
        },
        {
          "meaning": "silver (metal)",
          "connotation": "Material; couleur argent = silver color.",
          "exampleFr": "Une bague en argent.",
          "exampleEn": "A silver ring."
        }
      ]
    },
    "café": {
      "pos": "noun (m.)",
      "register": "neutral",
      "primary": "coffee",
      "senses": [
        {
          "meaning": "coffee (drink)",
          "connotation": "Un café = a coffee; very common order.",
          "exampleFr": "Un café, s'il vous plaît.",
          "exampleEn": "A coffee, please."
        },
        {
          "meaning": "café (establishment)",
          "connotation": "Often « au café » = at the café.",
          "exampleFr": "On se retrouve au café ?",
          "exampleEn": "Shall we meet at the café?"
        }
      ]
    },
    "politique": {
      "pos": "noun (f.) / adjective",
      "register": "formal to neutral",
      "primary": "politics / political",
      "senses": [
        {
          "meaning": "politics (field, activity)",
          "connotation": "La politique = politics as a domain.",
          "exampleFr": "Il s'intéresse à la politique.",
          "exampleEn": "He is interested in politics."
        },
        {
          "meaning": "policy (of a company, government)",
          "connotation": "Une politique de = a policy of.",
          "exampleFr": "La politique de l'entreprise.",
          "exampleEn": "The company's policy."
        }
      ]
    },
    "prix": {
      "pos": "noun (m.)",
      "register": "neutral",
      "primary": "price",
      "senses": [
        {
          "meaning": "price, cost",
          "connotation": "Quel est le prix ? = How much?",
          "exampleFr": "Le prix est trop élevé.",
          "exampleEn": "The price is too high."
        },
        {
          "meaning": "prize, award",
          "connotation": "Prix Nobel = Nobel Prize.",
          "exampleFr": "Il a gagné un prix.",
          "exampleEn": "He won a prize."
        }
      ]
    },
    "cours": {
      "pos": "noun (m.)",
      "register": "neutral",
      "primary": "course / class",
      "senses": [
        {
          "meaning": "course, class (lesson)",
